@article{Brito,
title = "Epidemiologia dos transtornos de condução e arritmias cardíacas no Brasil: internações e óbitos entre 2014 e 2024",
journal = "Brazilian Journal of Implantology and Health Sciences",
volume = "7",
pages = "1628 - 1640",
year = "2025",
note = "",
issn = "2674-8169",
doi = "https://doi.org/10.36557/2674-8169.2025v7n2p1628-1640",
url = "https://bjihs.emnuvens.com.br/bjihs/article/view/5209",
author = "Brito, P. V. M. B. and BOIKO , L. and DE NADAI, H. B. and CORADIM, M. da C. and CASADEI, J. C. de O. and RIBAS , V. L. and MAIA, G. C. and LOPES , I. and TAVARES , R. B. and DA SILVA, L. A. C. and CARRASCO, J. G. P. and RODRIGUES, V. C. and BAPTISTA , J. P. P. F. and CASALVARA, R. F. A. and PICOLO , V. C. D. and BHAY, S. S. and ZANATTA, S. and VORAKOSKI , A. V. and K{\"{O}}CHE, M. and SIMÕES, V. M.",
keywords = "Transtornos de condução, arritmia, epidemiologia, hospitalização, óbitos",
abstract = "O presente estudo tem como objetivo analisar a epidemiologia das internações e óbitos por transtornos de condução e arritmias cardíacas (TCAC) no Brasil no período de 2014 a 2024. Trata-se de uma pesquisa descritiva, transversal e epidemiológica. Os dados foram obtidos por meio do Departamento de Informática do Sistema Único de Saúde (DATASUS), considerando o período de 2014 a 2024. As variáveis analisadas incluíram região, sexo, faixa etária, raça, número de internações e óbitos por ano. A Região Sudeste apresentou os maiores índices de hospitalização (48,3%) e mortalidade, seguida pelo Sul e Nordeste. A predominância das internações foi observada em indivíduos do sexo masculino (52,6%) e na faixa etária de 70 a 79 anos (25,95%). O estudo também demonstrou que a maioria das hospitalizações ocorreu em caráter de urgência (81,06%). Houve um crescimento significativo das internações e óbitos ao longo do período analisado, destacando a necessidade de melhorias no diagnóstico precoce, ampliação do acesso a tratamentos especializados e fortalecimento das estratégias de prevenção e manejo das TCAC no Brasil.",
urldate = "10/11/2025",
urlaccessdate = "10 nov. 2025"
}

@article{Jesus,
title = "Prevalência e quadro hospitalar dos transtornos de condução e arritmias cardíacas: um estudo epidemiológico",
journal = "CONTRIBUCIONES A LAS CIENCIAS SOCIALES",
volume = "17",
pages = "e12442",
year = "2024",
note = "",
issn = "",
doi = "https://doi.org/10.55905/revconv.17n.12-073",
url = "https://ojs.revistacontribuciones.com/ojs/index.php/clcs/article/view/12442",
author = "Jesus, C. S. de and SILVA, T. da S. e and DONEDA, G. A. and SILVA, L. C. M. da and VIEIRA FILHO, M. C. A. and BARBOSA, V. C. and COSTA, M. C. and LEAL JUNIOR, R. C. A. and SALES, L. F. P. and BRAGA, A. D. S. and BOMFIM, E. N. and SOUZA, P. M. M. de and AVELAR, L. da S. and SILVEIRA, M. G. and DANTAS, C. C. F",
keywords = "arritmia, risco cardiovascular, transtornos de condução, taquicardias, morbidade, epidemiologia",
abstract = "Introdução: Os Transtornos de Condução e Arritmias Cardíacas (TCAC) são caracterizados por alterações no sistema de condução cardíaco. Apesar dos mecanismos, para que uma arritmia surja seria importante a interação de três fatores, sendo eles, a presença de um substrato, gatilhos, representados por extrassístoles e a presença de fatores moduladores. Objetivo: Esse artigo, objetiva trazer uma análise quantitativa e temporal sobre as características epidemiológicas dos transtornos de condução e arritmias cardíacas no período de Janeiro de 2014 a Junho de 2024. Metodologia: Trata-se de um  estudo  epidemiológico, retrospectivo com  abordagem quantitativa, realizado tendo  como  embasamento  os  dados  do  departamento de informação de saúde do SUS (Sistema  Único  de  Saúde). As variáveis utilizadas foram: internações hospitalares, média de permanência por internação, óbitos, faixa etária, cor/raça, sexo, por macrorregião. Resultados: Se fez possível observar, dentre 687.227 casos, a prevalência da região Sudeste quanto ao número de internações e número de óbitos, quando comparado a outras regiões do país. Já no quesito, média de permanência por internação, a região Nordeste se sobressai, e em relação à faixa etária foi registrado maior nos 80 anos e mais, deixando claro o risco cardiovascular aumentado de acordo com a idade. Conclusão: Doenças cardiovasculares são as principais causas de morte em todo o mundo. Diante do impacto significativo, é fundamental que profissionais de saúde considerem a necessidade de implementar e promover estratégias para evitar possíveis complicações. Posto isto, é imprescindível a disseminação de informações abrangentes e acessíveis sobre os Transtornos de Condução e Arritmias Cardíacas.",
urldate = "15/11/2025",
urlaccessdate = "15 nov. 2025"
}

